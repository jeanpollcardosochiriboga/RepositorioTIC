# Credenciales que usa el sistema de medición para conectarse por SSH.
# Copiar este archivo a .env y rellenar con los valores reales; el .env no se versiona.

# Contraseña del usuario raspberry1 en la Raspberry Pi (para sshpass y sudo remoto)
PI_PASS=tu_password_del_pi

# Contraseña SSH del router OpenWrt (usuario root por defecto)
ROUTER_PASS=tu_password_ssh_del_router
